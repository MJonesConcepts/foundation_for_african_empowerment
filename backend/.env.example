# Copy this to .env and fill in your values.
# Never commit .env to source control.

PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# Database (add when you wire up Postgres / Mongo / etc.)
# DATABASE_URL=postgresql://user:password@localhost:5432/teachforall

# Email delivery (add when wiring up contact form delivery)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# CONTACT_EMAIL_TO=info@teachforall.org
